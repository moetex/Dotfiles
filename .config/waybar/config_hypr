{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 6,

  "modules-left": [
    "hyprland/workspaces",
    "hyprland/submap"
  ],

  "modules-center": [
    "hyprland/window"
  ],

  "modules-right": [
    "pulseaudio#input",
    "pulseaudio#output",
    "network",
    "battery",
    "tray",
    "clock"
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true
  },

  "hyprland/submap": {
    "format": "в†”пёЏ{}",
    "max-length": 15,
    "tooltip-format": false
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 50
  },

  "clock": {
    "format": "{:%a, %B %d, %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "pulseaudio": {
    "format": "пЂЁ {volume}%",
    "format-muted": "п‘¦ muted",
    "on-click": "pavucontrol"
  },

  "pulseaudio#microphone": {
    "format": "п„° {volume}%",
    "format-muted": "п„± muted",
    "on-click": "pavucontrol"
  },

  "pulseaudio#input": {
    "format-source": "<span size='large'>п„°</span> {volume} %",
    "format-source-muted": "<span size='large'>п„±</span>  Muted",
    "format": "{format_source}",
    "tooltip-format": "{source_desc} | {source_volume} %",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%"
  },
  "pulseaudio#output": {
    "format": "<span size='large'>{icon}</span> {volume} %",
    "format-muted": "<span size='large'>п‘¦ </span>",
    "format-bluetooth": "<span size='large'>{icon}п–®</span> {volume}% <span size='large'>{format_source}</span>",
    "format-icons": {
      "headphone": "пџЉ",
      "headset": "пџЌ",
      "phone": "п‚•",
      "hdmi": "п‰¬",
      "default": ["пЂ¦", "пЂ§", "пЂЁ"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },

  "network": {
    "format-wifi": "п‡«  {gwaddr}",
    "format-ethernet": "Connected пѓЃ ",
    "tooltip-format": "{essid}, {ifname}, {signalStrength}% пћ–",
    "format-linked": "{ifname} (No IP) пћ–",
    "format-disconnected": "Disconnected вљ ",
    "on-click": "nm-connection-editor"
  },


  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "пѓ§ {capacity}%",
    "format-discharging": "п‰Ђ {capacity}%",
    "format-plugged": "п‡¦ {capacity}%"
  },

  "tray": {
    "spacing": 10
  },

  "custom/spotify": {
    "format": "п†ј {}",
    "max-length": 40,
    "exec": "playerctl metadata --format '{{artist}} - {{title}}' 2>/dev/null",
    "interval": 5,
    "return-type": "text",
    "on-click": "playerctl play-pause"
  }
}
