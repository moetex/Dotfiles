{
  "layer": "top",
  "position": "bottom",
  "height": 35,
  "spacing": 0,
  "margin-top": -3,
  "margin-bottom": 5,

  "margin-left": 10,
  "margin-right": 10,

  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": [],
  "modules-right": ["network", "custom/weather", "cpu", "memory", "temperature", "mpris", "pulseaudio#input", "pulseaudio#output", "battery", "tray", "sway/language", "clock"],

  "sway/language": {
    "format": "{short}",
    "tooltip": false
  },
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": false,
    "format": "{name}"
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "tray": {
    "icon-size": 20,
    "spacing": 15
  },
  "clock": {
    "format": "{:%a %B %d %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "format": "´íÜ {usage} %",
    "tooltip": false
  },
  "memory": {
    "format": "´öŞ {percentage} %",
    "tooltip": false
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "´őë {temperatureC} ┬░C",
    "format-icons": ["´Łź", "´őë", "´Łę"]
  },
  "battery": {
    "states": { "warning": 30, "critical": 20 },
    "format": "­čöő {capacity}%",
    "format-charging": "{capacity}% ´çŽ",
    "format-plugged": "{capacity}% ´çŽ",
    "format-alt": "{time} {icon}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },
  "network": {
