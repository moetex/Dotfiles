    "format-linked": "{ifname} (No IP) ´×ľ",
    "format-disconnected": "Disconnected ÔÜá",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio#input": {
    "format-source": "<span size='large'>´ä░</span> {volume} %",
    "format-source-muted": "<span size='large'>´ä▒</span>  Muted",
    "format": "{format_source}",
    "tooltip-format": "{source_desc} | {source_volume} %",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%"
  },
  "pulseaudio#output": {
    "format": "<span size='large'>{icon}</span> {volume} %",
    "format-muted": "<span size='large'>´ĹŽ </span>",
    "format-bluetooth": "<span size='large'>{icon}´ľ«</span> {volume}% <span size='large'>{format_source}</span>",
    "format-icons": {
      "headphone": "´čŐ",
      "headset": "´čŹ",
      "phone": "´éĽ",
      "hdmi": "´ëČ",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },
  "mpris": {
    "format": "´ć╝ {artist} - {title}",
    "tooltip": false,
    "max-length": 40,
    "player": "spotify",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "format-icons": { "Playing": "´üő", "Paused": "´üî" }
  },
  "custom/weather": {
